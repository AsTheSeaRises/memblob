# Backend: 'local' (fully on-device via Ollama) or 'api' (OpenAI-compatible provider)
MEMBLOB_BACKEND=api

# --- API backend (required if MEMBLOB_BACKEND=api) ---
API_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
API_CHAT_MODEL=qwen-plus
API_EMBED_MODEL=text-embedding-v4
API_KEY=sk-your-key-here
# Other providers: set API_BASE_URL + API_KEY to match (any OpenAI-compatible endpoint works)
# DashScope users: API_KEY also falls back to DASHSCOPE_API_KEY if set

# --- Local backend (required if MEMBLOB_BACKEND=local) ---
# OLLAMA_EMBED_MODEL=nomic-embed-text
# OLLAMA_EXTRACT_MODEL=gemma4:e2b
# (Ollama must be running at http://localhost:11434)
